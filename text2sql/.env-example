# PostgreSQL connection settings for text2sql/setup_dw_pg.py
# Copy to .env and fill with your values.

# Preferred: explicit DSN
PG_DSN=postgresql://postgres:my_password@localhost:5432/sales_dw

# Alternatively, or if PG_DSN is empty, these individual values are used.
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=my_password
PGDATABASE=sales_dw
